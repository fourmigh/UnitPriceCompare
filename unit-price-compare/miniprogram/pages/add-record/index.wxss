.section {
  margin-bottom: 24rpx;
}

.optional {
  padding-left: 20rpx;
  border-left: 4rpx solid #e0e0e0;
}

.optional-label::after {
  content: "（可选）";
  font-size: 22rpx;
  color: #bbb;
  margin-left: 8rpx;
}

.required .label::after {
  content: " *";
  color: #e53935;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.input {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  border: 2rpx solid #eee;
}

.readonly-text {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #1d1d1f;
  display: block;
}

.picker {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  border: 2rpx solid #eee;
  color: #1d1d1f;
}

.divider {
  height: 2rpx;
  background: #e8e8e8;
  margin: 30rpx 0;
}

.preview {
  background: #f0f5ff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.preview-text {
  font-size: 28rpx;
  color: #3964fe;
  display: block;
}

.per-piece {
  margin-top: 8rpx;
  opacity: 0.8;
}


