<page-layout bar-text="{{_t.index.addBtn}}" bar-disabled="{{false}}" bindbartap="goToAdd">
  <view class="header">
    <text class="title">{{_t.app.title}}</text>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>{{_t.common.loading}}</text>
  </view>

  <view wx:elif="{{products.length === 0}}" class="empty">
    <image src="/images/default-goods-image.png" mode="widthFix" class="empty-img" />
    <text class="empty-text">{{_t.index.empty}}</text>
  </view>

  <view wx:else class="list">
    <view
      class="card"
      wx:for="{{products}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="goToDetail"
    >
      <view class="card-body">
        <text class="card-brand">{{item.brand}}</text>
        <text class="card-name">{{item.productName}}</text>
      </view>
    </view>
  </view>
</page-layout>
