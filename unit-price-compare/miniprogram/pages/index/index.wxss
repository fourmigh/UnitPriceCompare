.page {
  padding: 20rpx 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.add-btn {
  background: #3964fe;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
  line-height: 1.5;
}

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: #999;
  font-size: 28rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.4;
}

.empty-btn {
  margin-top: 30rpx;
  background: #3964fe;
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  padding: 16rpx 50rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-brand {
  font-size: 24rpx;
  color: #888;
}

.card-name {
  font-size: 32rpx;
  color: #1d1d1f;
  font-weight: 500;
}
