.loading {
  text-align: center;
  padding-top: 200rpx;
  color: #999;
  font-size: 28rpx;
}

.product-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 30rpx;
  position: relative;
}

.brand {
  font-size: 26rpx;
  color: #888;
  display: block;
}

.name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.spec-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.spec-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1d1d1f;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  font-size: 26rpx;
}

.price-row.top-rank {
  background: #fffde7;
  border-radius: 8rpx;
  margin: 0 -16rpx;
  padding: 14rpx 16rpx;
  border: 2rpx solid #ffe082;
}

.price-header {
  color: #999;
  border-bottom: 2rpx solid #f0f0f0;
}

.per-piece-row {
  display: flex;
  align-items: center;
  padding: 0 0 14rpx 0;
  font-size: 22rpx;
  margin-top: -6rpx;
}

.rank-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #e0e0e0;
  color: #666;
  font-size: 20rpx;
  font-weight: 600;
}

.rank-badge.gold {
  background: #ffc107;
  color: #fff;
}

.col {
  flex: 1;
}

.rank { width: 56rpx; flex-shrink: 0; text-align: center; }
.platform { flex: 1; }
.shop { flex: 1.2; }
.price { flex: 0.8; text-align: right; }
.unit-price { flex: 1; text-align: right; }

.highlight {
  color: #3964fe;
  font-weight: 500;
}

.per-piece-text {
  color: #999;
}

.tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 6rpx;
  vertical-align: middle;
}

.tag.online {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag.offline {
  background: #fff3e0;
  color: #e65100;
}
